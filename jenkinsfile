pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                git 'https://github.com/DivyaGhadi/coffee-shop-devops.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t coffee-shop-ui .'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 8080:80 coffee-shop-ui'
            }
        }
    }
}
